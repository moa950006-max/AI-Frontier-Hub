rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: news
    // Document ID: base64 hash of original ID
    // Fields:
    //   - id: string (required) - original GUID/link
    //   - title: string (required) - news title
    //   - link: string (required) - full story URL
    //   - pubDate: string (required, ISO 8601) - publication date
    //   - content: string (optional) - full content
    //   - source: string (required) - source name
    //   - category: string (required) - news category
    //   - summary: string (optional) - short summary
    //   - imageUrl: string (optional) - image URL
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "moa950006@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidNews(data) {
      return data.keys().hasAll(['id', 'title', 'link', 'pubDate', 'source', 'category']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 1000 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 1000 &&
             data.link is string && data.link.size() > 0 && data.link.size() < 2000 &&
             data.pubDate is string && data.pubDate.size() > 0 &&
             data.source is string && data.source.size() > 0 && data.source.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /news/{newsId} {
      // Allow anyone (even unauthenticated) to read news
      // In a real production app, you might want to require auth, but for a news hub, public read is common.
      // However, per instructions: "Initially restricted: Never make any collection or data publicly readable, 
      // always require authentication for any access to data unless the user makes an explicit request for unauthenticated data."
      // The user wants to deploy to web, so public read is likely desired, but I'll stick to auth required for now.
      allow read: if isAuthenticated();
      
      // Only admins (or the backend server) can create/update/delete news
      // In this environment, the backend server often uses admin credentials which bypass rules.
      allow create: if isAdmin() && isValidNews(request.resource.data);
      allow update: if isAdmin() && isValidNews(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && (request.resource.data.role == 'user' || isAdmin());
    }
  }
}
